# =============================================================================
# 环境变量模板：复制为 .env 后填写（.env 已被 .gitignore 忽略，勿提交仓库）
# 应用启动时由 config.py 通过 python-dotenv 加载项目根目录下的 .env
# =============================================================================

# -----------------------------------------------------------------------------
# 猎聘登录（按需；部分流程依赖 Playwright 人工登录时可为空）
# -----------------------------------------------------------------------------
# 猎聘账号手机号或邮箱
LOGIN_USERNAME=
# 猎聘密码（若仅用浏览器人工登录保存 storage_state，可留空）
LOGIN_PASSWORD=

# -----------------------------------------------------------------------------
# 验证码（按需；猎聘登录滑块等可走 2Captcha 等，见 config.captcha_api_key）
# -----------------------------------------------------------------------------
captcha_api_key=

# -----------------------------------------------------------------------------
# 通义千问 / 百炼（文本 LLM、场景解析、岗位初筛与精筛等）
# -----------------------------------------------------------------------------
# 百炼 API Key（必填，否则 LLM 相关接口不可用）
DASHSCOPE_API_KEY=
# 与 Key 所属地域一致；华北 2（北京）常用 compatible-mode，其它地域见百炼文档
DASHSCOPE_BASE_HTTP_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 历史标记项，代码里仍有读取；文本实际走下方 LLM_CHAT_MODEL
LLM_MODEL=dashscope-chat
# 百炼 OpenAI 兼容 chat.completions 的模型 id，如 qwen-flash、qwen3 系列等
LLM_CHAT_MODEL=qwen-flash
# 可选：OpenAI 兼容客户端超时（毫秒），文本与部分调用共用
# LLM_REQUEST_TIMEOUT_MS=120000
# 可选：chat.completions 的 max_tokens（长 JSON / 结构化输出可调大，见 config 默认 6000）
# LLM_MAX_TOKENS=6000

# -----------------------------------------------------------------------------
# 记忆向量 / 第三方 OpenAI 兼容网关（嵌入等；变量名与 config 一致：openai_API_KEY）
# -----------------------------------------------------------------------------
openai_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# 须含 /v1；留空时 config 内仍有代码侧默认，建议在 .env 中显式配置
OPENAI_API_BASE=https://ai.nengyongai.cn/v1

# -----------------------------------------------------------------------------
# 猎聘岗位详情：HTML 解析 vs 截屏 + 多模态（与 crawlers.liepin_vlm 等一致）
# -----------------------------------------------------------------------------
# True=截屏走百炼 VLM；False=仅用 HTML 解析（省成本、速度快）
VLM_ENABLED=False
# 百炼视觉模型 id，如 qwen-vl-ocr-latest
VLM_MODEL=qwen-vl-ocr-latest
# 可选：输入图像像素上下限（与官方示例一致时可取消注释）
# VLM_IMAGE_MIN_PIXELS=3072
# VLM_IMAGE_MAX_PIXELS=8388608
# 可选：VLM 单次请求超时（毫秒）
# VLM_REQUEST_TIMEOUT_MS=120000

# -----------------------------------------------------------------------------
# 爬虫列表页数（测试建议 1；正式可调大，注意风控）
# -----------------------------------------------------------------------------
MAX_PAGE=1

# -----------------------------------------------------------------------------
# LangGraph：POST /api/agent/run 内用 requests 回调本机 API（须与服务监听地址一致）
# -----------------------------------------------------------------------------
# 未设置时 config 默认为 http://127.0.0.1:{PORT}（PORT 见 config.py，勿用 0.0.0.0 作主机）
# AGENT_API_BASE_URL=http://127.0.0.1:8000
# 可选：各步骤 HTTP 超时（秒），见 agent_orchestrator.AgentHttpConfig.from_env
# AGENT_TIMEOUT_LOGIN_S=600
# AGENT_TIMEOUT_CRAWL_S=900
# AGENT_TIMEOUT_PREFILTER_S=600
# AGENT_TIMEOUT_SUBMIT_S=600
