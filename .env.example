# 复制本文件为 .env 并填写（.env 已被 .gitignore 忽略，勿提交仓库）
# 应用启动时由 config.py 通过 python-dotenv 加载项目根目录下的 .env

LOGIN_USERNAME=
LOGIN_PASSWORD=
captcha_api_key=
# 文本 LLM 已改为百炼 OpenAI 兼容接口（见 LLM_CHAT_MODEL），此项仅作标记
LLM_MODEL=dashscope-chat
DASHSCOPE_API_KEY=
# 华北2（北京）等地域的 OpenAI 兼容入口，与 Key 地域一致，其它地域见百炼文档
# DASHSCOPE_BASE_HTTP_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 文本 chat.completions 模型（官方示例：qwen-flash）
LLM_CHAT_MODEL=qwen-flash
# 可选，文本/VLM 共用 OpenAI 客户端超时（毫秒），见 config
# LLM_REQUEST_TIMEOUT_MS=120000
# 可选，chat.completions 的 max_tokens（结构化 JSON 场景）
# LLM_MAX_TOKENS=2048
# 猎聘岗位详情：True 时用截屏 + 多模态 归纳，False 时仅用 HTML 解析
VLM_ENABLED=False
# 百炼 VL OCR 等，官方示例：qwen-vl-ocr-latest
VLM_MODEL=qwen-vl-ocr-latest
# 可选，与官方示例一致的图像像素阈
# VLM_IMAGE_MIN_PIXELS=3072
# VLM_IMAGE_MAX_PIXELS=8388608
# 可选，VLM 单次 API 超时（毫秒）
# VLM_REQUEST_TIMEOUT_MS=120000
openai_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_BASE=https://ai.nengyongai.cn/v1
MAX_PAGE=1
